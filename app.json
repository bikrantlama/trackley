{
  "expo": {
    "name": "Trackley",
    "slug": "trackley",
    "version": "1.0.0",
    "runtimeVersion": {
      "policy": "sdkVersion"
    },
    "orientation": "portrait",
    "icon": "./assets/images/logo.png",
    "scheme": "trackley",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,

    "splash": {
      "image": "./assets/images/logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#0D0D1A"
    },

    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.bikrantlama.trackley",
      "buildNumber": "1",
      "infoPlist": {
        "NSMotionUsageDescription": "Trackley uses motion data to count your daily steps and track your activity.",
        "NSCameraUsageDescription": "Trackley uses your camera to let you upload a profile photo.",
        "NSPhotoLibraryUsageDescription": "Trackley accesses your photo library so you can set a profile photo or add progress photos.",
        "NSUserNotificationsUsageDescription": "Trackley sends reminders to help you complete your daily habits on time.",
        "UIBackgroundModes": ["fetch", "remote-notification"]
      },
      "googleServicesFile": "./GoogleService-Info.plist",
      "config": {
        "usesNonExemptEncryption": false
      }
    },

    "android": {
      "package": "com.bikrantlama.trackley",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/logo.png",
        "backgroundColor": "#0D0D1A"
      },
      "permissions": [
        "android.permission.ACTIVITY_RECOGNITION",
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.SCHEDULE_EXACT_ALARM",
        "android.permission.USE_EXACT_ALARM",
        "android.permission.CAMERA",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.POST_NOTIFICATIONS"
      ],
      "googleServicesFile": "./google-services.json"
    },

    "web": {
      "favicon": "./assets/images/logo.png",
      "bundler": "metro"
    },

    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://trackley.app"
        }
      ],
      "expo-font",
      "expo-web-browser",
      "@react-native-community/datetimepicker",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/logo.png",
          "color": "#10D9A0",
          "sounds": []
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Trackley accesses your photo library to let you set a profile photo or add progress photos.",
          "cameraPermission": "Trackley uses your camera to take a profile or progress photo."
        }
      ],
      [
        "expo-sensors",
        {
          "motionPermission": "Trackley uses motion data to count your daily steps."
        }
      ]
    ],

    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },

    "extra": {
      "eas": {
        "projectId": "your-eas-project-id"
      }
    },

    "updates": {
      "url": "https://u.expo.dev/your-eas-project-id",
      "enabled": true,
      "checkAutomatically": "ON_LOAD",
      "fallbackToCacheTimeout": 0
    }
  }
}
